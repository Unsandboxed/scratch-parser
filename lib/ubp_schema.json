{
    "$id": "https://unsandboxed.org/ubp_schema.json",
    "$schema": "http://json-schema.org/schema#",
    "description": "Unsandboxed UBP Project Schema",
    "type": "object",
    "properties": {
        "meta": {
            "type": "object",
            "properties": {
                "semver": {
                    "type": "string",
                    "pattern": "^(3\\.[0-9]+\\.[0-9]+)$"
                },
                "vm": {
                    "type": "string",
                    "pattern": "^([0-9]+\\.[0-9]+\\.[0-9]+)($|-)"
                },
                "agent": {
                    "type": "string"
                },
                "origin": {
                    "type": "string"
                },
                "ubpVersion": {
                    "type": "integer",
                    "minimum": 1
                },
                "ubp": {
                    "type": "integer",
                    "enum": [1]
                }
            },
            "required": ["semver"],
            "anyOf": [
                {
                    "required": ["ubpVersion"]
                },
                {
                    "required": ["ubp"]
                }
            ]
        },
        "targets": {
            "type": "array",
            "items": [
                {
                    "allOf": [
                        {"$ref": "ubp_definitions.json#/definitions/stage" },
                        {"$ref": "ubp_definitions.json#/definitions/target"}
                    ]
                }
            ],
            "additionalItems": {
                "allOf": [
                    {"$ref": "ubp_definitions.json#/definitions/sprite"},
                    {"$ref": "ubp_definitions.json#/definitions/target"}
                ]
            }
        }
    },
    "required": [
        "meta",
        "targets"
    ]
}
